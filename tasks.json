    {
      "id": "phase-4",
      "name": "Database Migration & Monitor Management",
      "branch": "phase-4-management",
      "status": "pending",
      "description": "Migrate to Supabase for persistent storage, then add CRUD operations for monitors, clients, and settings",
      "prerequisites": [
        "Supabase project created",
        "Environment variables configured (SUPABASE_URL, SUPABASE_ANON_KEY, SUPABASE_SERVICE_KEY)"
      ],
      "tasks": [
        {
          "id": "4.0.1",
          "title": "Supabase database schema",
          "description": "Design and create PostgreSQL schema for monitors, checks, incidents, and configuration",
          "status": "pending",
          "priority": "critical",
          "blocksOtherTasks": true,
          "files": [
            "supabase/schema.sql",
            "supabase/seed.sql",
            "supabase/migrations/"
          ],
          "schema": {
            "tables": [
              "websites - Monitor configuration (replaces config.json)",
              "clients - Client/customer information",
              "monitor_checks - Time-series check results",
              "incidents - Aggregated downtime events",
              "visual_baselines - Metadata for baseline screenshots",
              "alert_history - Email/notification log"
            ],
            "indexes": [
              "idx_checks_website_timestamp - Fast time-series queries",
              "idx_incidents_website_started - Incident lookups",
              "idx_checks_status - Status filtering"
            ],
            "functions": [
              "calculate_uptime(website_id, hours) - Server-side uptime calc",
              "get_recent_incidents(website_id, limit) - Fast incident queries"
            ]
          },
          "features": [
            "Monitor configuration table (name, url, client_id, settings)",
            "Time-series checks table (optimized for inserts)",
            "Incidents table with start/end timestamps",
            "Client management table",
            "Indexes for fast queries",
            "Foreign key constraints for data integrity",
            "Partitioning for check data (future optimization)"
          ]
        },
        {
          "id": "4.0.2",
          "title": "Supabase Storage setup",
          "description": "Configure Storage buckets for screenshots and baselines",
          "status": "pending",
          "priority": "critical",
          "blocksOtherTasks": true,
          "files": [
            "supabase/storage-policies.sql"
          ],
          "features": [
            "Create 'baselines' bucket for visual comparison images",
            "Create 'screenshots' bucket for snapshots",
            "Set up RLS policies for security",
            "Configure public URL access for images",
            "Set retention policies (auto-delete old snapshots)"
          ]
